# Copy to .env and fill in values. Never commit .env.

# --- Telegram bot (required only for the Telegram file intake path) ---
# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram numeric user ID(s) — the ONLY senders the bot will accept files
# from. Comma-separated for multiple (e.g. several of your own devices/accounts).
# Get yours by messaging @userinfobot. REQUIRED for the bot to accept anything:
# if unset, the bot rejects every sender (fail-closed) so strangers who find the
# bot cannot push files into your storage.
TELEGRAM_OWNER_ID=

# Public base URL of this GuardBox instance (no trailing slash)
# Example: https://guardbox.example.com
GUARDBOX_BASE_URL=

# Set to false only in local dev when TLS is not configured (default: true)
SESSION_SECURE_COOKIE=true

# Internal server key — used to cryptographically sign cookies so they can't be forged.
# This is NOT the login password. The login password is created on first boot via the setup page.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# local (KVM disk + JSON sidecars) | cloud (S3 + Postgres — not yet implemented)
STORAGE_BACKEND=local

# Root directory for local storage. Defaults to /data/guardbox if unset.
STORAGE_ROOT=

# Cloud storage (required only when STORAGE_BACKEND=cloud)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
DATABASE_URL=
