# Copy to .env and fill in values. Never commit .env.

# Telegram bot token from @BotFather
BOT_TOKEN=

# local (KVM disk + JSON sidecars) | cloud (S3 + Postgres — not yet implemented)
STORAGE_BACKEND=local

# Root directory for local storage. Defaults to /data/guardbox if unset.
STORAGE_ROOT=

# Cloud storage (required only when STORAGE_BACKEND=cloud)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
DATABASE_URL=
